{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2023", "DOM"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "vite.config.ts", "playwright.config.ts", "tests/**/*.ts"]
}
