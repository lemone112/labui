{
  "name": "@lab-ui/tokens",
  "version": "0.1.0",
  "description": "Lab UI design tokens — OKLCH colors, spacing, typography, radius, shadows",
  "type": "module",
  "main": "dist/index.css",
  "exports": {
    ".": "./dist/index.css",
    "./css/light": "./dist/css/light.css",
    "./css/dark": "./dist/css/dark.css",
    "./css/brand": "./dist/css/brand.css",
    "./css/*": "./dist/css/*.css",
    "./tailwind": "./dist/tailwind/theme.css"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsx src/build.ts",
    "lint": "tsx src/lint.ts",
    "clean": "rm -rf dist generated",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@texel/color": "^1.0.0",
    "@tokens-studio/sd-transforms": "^2.0.0",
    "@types/node": "^22.0.0",
    "style-dictionary": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": ["design-tokens", "oklch", "tailwindcss", "css-variables"],
  "license": "MIT"
}
