{
  "name": "@lab-ui/tokens",
  "version": "0.2.0",
  "description": "Lab UI design tokens — OKLCH colors, parametric cells, 4-mode (light/dark/IC) output",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": "./dist/tailwind-preset.css"
  },
  "files": [
    "dist/",
    "config/",
    "src/",
    "spec.md",
    "README.md"
  ],
  "scripts": {
    "apca-baseline": "bun run scripts/generate-apca-baseline.ts",
    "build": "bun run src/build.ts",
    "build:node": "tsx src/build.ts",
    "dev": "bun run --watch src/build.ts",
    "test": "bun test",
    "test:node": "node --import tsx --test tests/*.test.ts",
    "clean": "rm -rf dist",
    "lint": "bun run src/build.ts",
    "catalog": "bun run scripts/generate-test-catalog.ts",
    "coverage": "bun run scripts/verify-plan-coverage.ts",
    "fetch-figma": "bun run scripts/fetch-figma-anchors.ts",
    "semantic-diff": "bun run scripts/semantic-diff.ts"
  },
  "dependencies": {
    "apca-w3": "^0.1.9",
    "colorparsley": "^0.1.8",
    "culori": "^4.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.11",
    "@types/culori": "^2.1.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "design-tokens",
    "oklch",
    "apca",
    "display-p3",
    "css-variables"
  ],
  "license": "MIT"
}
