{
  "$schema": "https://tr.designtokens.org/format/",
  "opacity": {
    "$description": "9-stop opacity scale from Figma. Used to generate alpha variants at build time.",
    "2":   { "$type": "number", "$value": 0.02, "$description": "Ghost" },
    "4":   { "$type": "number", "$value": 0.04, "$description": "Subtle" },
    "8":   { "$type": "number", "$value": 0.08 },
    "12":  { "$type": "number", "$value": 0.12 },
    "20":  { "$type": "number", "$value": 0.20 },
    "32":  { "$type": "number", "$value": 0.32 },
    "52":  { "$type": "number", "$value": 0.52 },
    "72":  { "$type": "number", "$value": 0.72 },
    "80":  { "$type": "number", "$value": 0.80, "$description": "Near-solid" }
  }
}
