      "$value": "oklch(0.748 0.130 189)",
      "$description": "Decorative mint (#00C7BE)",
      "$extensions": { "lab-ui": { "hex": "#00C7BE" } }
    },
    "indigo": {
      "$type": "color",
      "$value": "oklch(0.529 0.191 278)",
      "$description": "Decorative indigo (#5856D6)",
      "$extensions": { "lab-ui": { "hex": "#5856D6" } }
    },
    "purple": {
      "$type": "color",
      "$value": "oklch(0.615 0.213 312)",
      "$description": "Decorative purple (#AF52DE)",
      "$extensions": { "lab-ui": { "hex": "#AF52DE" } }
    },
    "pink": {
