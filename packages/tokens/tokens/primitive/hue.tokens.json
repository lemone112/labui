{
  "$schema": "https://tr.designtokens.org/format/",
  "hue": {
    "$description": "Base accent hues. Verified via Color.js (sRGB → OKLab → OKLCH). Brand configurable via --brand-hue.",
    "brand": {
      "$type": "color",
      "$value": "oklch(0.603 0.218 257)",
      "$description": "Primary brand color (#007AFF). Hue configurable at runtime.",
      "$extensions": {
        "lab-ui": { "hex": "#007AFF", "hue": 257, "role": "brand", "configurable": true }
      }
    },
    "danger": {
      "$type": "color",
      "$value": "oklch(0.654 0.232 29)",
      "$description": "Danger/error (#FF3B30). Fixed hue — red is always danger.",
      "$extensions": {
        "lab-ui": { "hex": "#FF3B30", "hue": 29, "role": "sentiment", "configurable": false }
      }
    },
    "warning": {
      "$type": "color",
      "$value": "oklch(0.786 0.172 69)",
      "$description": "Warning/caution (#FFA100). Fixed hue — orange is always warning.",
      "$extensions": {
        "lab-ui": { "hex": "#FFA100", "hue": 69, "role": "sentiment", "configurable": false }
      }
    },
    "success": {
      "$type": "color",
      "$value": "oklch(0.730 0.194 147)",
      "$description": "Success/positive (#34C759). Fixed hue — green is always success.",
      "$extensions": {
        "lab-ui": { "hex": "#34C759", "hue": 147, "role": "sentiment", "configurable": false }
      }
    },
    "info": {
      "$type": "color",
      "$value": "oklch(0.640 0.193 260)",
      "$description": "Informational (#3E87FF). Derived from brand hue at runtime.",
      "$extensions": {
        "lab-ui": { "hex": "#3E87FF", "hue": "brand", "role": "sentiment", "configurable": false }
      }
    },
    "yellow": {
      "$type": "color",
      "$value": "oklch(0.873 0.179 92)",
      "$description": "Decorative yellow (#FFD000)",
      "$extensions": { "lab-ui": { "hex": "#FFD000" } }
    },
    "teal": {
