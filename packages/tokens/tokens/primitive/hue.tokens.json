{
  "$schema": "https://tr.designtokens.org/format/",
  "hue": {
    "$description": "Base accent hues. Brand is configurable via --brand-hue. Sentiments are fixed.",
    "brand": {
      "$type": "color",
      "$value": "oklch(0.588 0.220 259)",
      "$description": "Primary brand color. Hue configurable at runtime via --brand-hue.",
      "$extensions": {
        "lab-ui": { "hue": 259, "role": "brand", "configurable": true }
      }
    },
    "danger": {
      "$type": "color",
      "$value": "oklch(0.634 0.232 25)",
      "$description": "Danger/error. Fixed hue — red is always danger.",
      "$extensions": {
        "lab-ui": { "hue": 25, "role": "sentiment", "configurable": false }
      }
    },
    "warning": {
      "$type": "color",
      "$value": "oklch(0.750 0.160 75)",
      "$description": "Warning/caution. Fixed hue — orange is always warning.",
      "$extensions": {
        "lab-ui": { "hue": 75, "role": "sentiment", "configurable": false }
      }
    },
    "success": {
      "$type": "color",
      "$value": "oklch(0.700 0.190 152)",
      "$description": "Success/positive. Fixed hue — green is always success.",
      "$extensions": {
        "lab-ui": { "hue": 152, "role": "sentiment", "configurable": false }
      }
    },
    "info": {
      "$type": "color",
      "$value": "oklch(0.630 0.195 255)",
      "$description": "Informational. Derived from brand hue at runtime.",
      "$extensions": {
        "lab-ui": { "hue": "brand", "role": "sentiment", "configurable": false }
      }
    },
    "yellow": {
      "$type": "color",
