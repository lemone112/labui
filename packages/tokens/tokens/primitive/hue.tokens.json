      "$value": "oklch(0.532 0.195 289)",
      "$description": "Decorative indigo"
    },
    "purple": {
      "$type": "color",
      "$value": "oklch(0.589 0.210 310)",
      "$description": "Decorative purple"
    },
    "pink": {
