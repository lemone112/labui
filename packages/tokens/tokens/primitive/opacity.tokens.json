{
  "$schema": "https://tr.designtokens.org/format/",
  "opacity": {
    "$description": "19-stop opacity scale. Symmetric: dense at both ends (subtle + near-solid), linear in middle. Used to generate alpha variants of all hues at build time.",
    "0":    { "$type": "number", "$value": 0,    "$description": "Transparent" },
    "10":   { "$type": "number", "$value": 0.01, "$description": "Ghost" },
    "25":   { "$type": "number", "$value": 0.03, "$description": "Subtle" },
    "50":   { "$type": "number", "$value": 0.05  },
    "75":   { "$type": "number", "$value": 0.08  },
    "100":  { "$type": "number", "$value": 0.10  },
    "200":  { "$type": "number", "$value": 0.20  },
    "300":  { "$type": "number", "$value": 0.30  },
    "400":  { "$type": "number", "$value": 0.40  },
    "500":  { "$type": "number", "$value": 0.50  },
    "600":  { "$type": "number", "$value": 0.60  },
    "700":  { "$type": "number", "$value": 0.70  },
    "800":  { "$type": "number", "$value": 0.80  },
    "900":  { "$type": "number", "$value": 0.90  },
    "925":  { "$type": "number", "$value": 0.93  },
    "950":  { "$type": "number", "$value": 0.95  },
    "975":  { "$type": "number", "$value": 0.98  },
    "990":  { "$type": "number", "$value": 0.99  },
    "1000": { "$type": "number", "$value": 1.00, "$description": "Solid" }
  }
}
