{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Increased Contrast accent hue overrides. Phase 2. Verified via Color.js.",
  "hue-ic": {
    "light": {
      "$description": "Light IC: darker accents for higher contrast on white backgrounds",
      "brand":   { "$type": "color", "$value": "oklch(0.464 0.242 263)", "$extensions": { "lab-ui": { "hex": "#0040DD" } } },
      "danger":  { "$type": "color", "$value": "oklch(0.553 0.225 27)",  "$extensions": { "lab-ui": { "hex": "#D70015" } } },
      "warning": { "$type": "color", "$value": "oklch(0.552 0.192 35)",  "$extensions": { "lab-ui": { "hex": "#C93400" } } },
      "success": { "$type": "color", "$value": "oklch(0.558 0.146 148)", "$extensions": { "lab-ui": { "hex": "#248A3D" } } },
      "info":    { "$type": "color", "$value": "oklch(0.479 0.207 261)", "$extensions": { "lab-ui": { "hex": "#0050CF" } } }
    },
    "dark": {
      "$description": "Dark IC: lighter accents for higher contrast on dark backgrounds",
      "brand":   { "$type": "color", "$value": "oklch(0.685 0.170 253)", "$extensions": { "lab-ui": { "hex": "#409CFF" } } },
      "danger":  { "$type": "color", "$value": "oklch(0.698 0.193 24)",  "$extensions": { "lab-ui": { "hex": "#FF6161" } } },
      "warning": { "$type": "color", "$value": "oklch(0.802 0.153 67)",  "$extensions": { "lab-ui": { "hex": "#FFA940" } } },
      "success": { "$type": "color", "$value": "oklch(0.782 0.218 147)", "$extensions": { "lab-ui": { "hex": "#30DB5B" } } },
      "info":    { "$type": "color", "$value": "oklch(0.801 0.101 258)", "$extensions": { "lab-ui": { "hex": "#95C0FF" } } }
    }
  }
}
