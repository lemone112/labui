{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Glassmorphism material recipes. 5 levels. Light = color-dodge blend, Dark = overlay blend.",

  "material": {
    "subtle": {
      "$description": "Lightest glass — barely visible blur",
      "opacity": { "$type": "number", "$value": 0.44 },
      "blur":    { "$type": "dimension", "$value": { "value": 6, "unit": "px" } },
      "blend":   { "$type": "string", "$value": "color-dodge" },
      "$extensions": { "lab-ui": { "dark-blend": "overlay" } }
    },
    "soft": {
      "$description": "Soft frosted surface",
      "opacity": { "$type": "number", "$value": 0.70 },
      "blur":    { "$type": "dimension", "$value": { "value": 12, "unit": "px" } },
      "blend":   { "$type": "string", "$value": "color-dodge" },
      "$extensions": { "lab-ui": { "dark-blend": "overlay" } }
    },
    "muted": {
      "$description": "Standard glass surface",
      "opacity": { "$type": "number", "$value": 0.82 },
      "blur":    { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
      "blend":   { "$type": "string", "$value": "color-dodge" },
      "$extensions": { "lab-ui": { "dark-blend": "overlay" } }
    },
    "base": {
      "$description": "Dense glass — most content readable",
      "opacity": { "$type": "number", "$value": 0.94 },
      "blur":    { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
      "blend":   { "$type": "string", "$value": "color-dodge" },
      "$extensions": { "lab-ui": { "dark-blend": "overlay" } }
    },
    "elevated": {
      "$description": "Strongest glass — floating panels, popovers",
      "opacity": { "$type": "number", "$value": 0.80 },
      "blur":    { "$type": "dimension", "$value": { "value": 64, "unit": "px" } },
      "blend":   { "$type": "string", "$value": "color-dodge" },
      "$extensions": { "lab-ui": { "dark-blend": "overlay" } }
    }
  }
}
