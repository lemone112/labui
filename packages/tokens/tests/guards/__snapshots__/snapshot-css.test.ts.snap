    --fx-shadow-ambient: oklch(0.08 0 0 / 0.02);
    --fx-shadow-penumbra: oklch(0.08 0 0 / 0.04);
    --fx-shadow-major: oklch(0.08 0 0 / 0.12);
    --badge-label-contrast: oklch(1 0 0);
    --badge-label-default: oklch(0.08 0 0);
    --control-bg: oklch(0.575 0.012 286 / 0.36);
    --fx-shadow-xs: 0px 1px 2px 0px var(--fx-shadow-minor);
    --fx-shadow-s: 0px 1px 3px 0px var(--fx-shadow-minor), 0px 2px 4px 0px var(--fx-shadow-ambient);
    --fx-shadow-m: 0px 2px 6px 0px var(--fx-shadow-minor), 0px 4px 12px 0px var(--fx-shadow-ambient), 0px 1px 3px 0px var(--fx-shadow-major);
    --fx-shadow-l: 0px 4px 12px 0px var(--fx-shadow-minor), 0px 8px 24px 0px var(--fx-shadow-ambient), 0px 2px 6px 0px var(--fx-shadow-penumbra), 0px 1px 3px 0px var(--fx-shadow-major);
    --fx-shadow-xl: 0px 48px 96px 0px var(--fx-shadow-minor), 0px 24px 48px 0px var(--fx-shadow-ambient), 0px 8px 24px 0px var(--fx-shadow-penumbra), 0px 2px 8px 0px var(--fx-shadow-major);
  }
}

:root {
  --materials-elevated-bg: var(--neutral-0);
  --materials-elevated-filter: none;
  --materials-elevated-backdrop-filter: none;
  --materials-base-bg: var(--neutral-1);
  --materials-base-filter: none;
  --materials-base-backdrop-filter: none;
  --materials-muted-bg: var(--neutral-2);
  --materials-muted-filter: none;
  --materials-muted-backdrop-filter: none;
  --materials-soft-bg: var(--neutral-3);
  --materials-soft-filter: none;
  --materials-soft-backdrop-filter: none;
  --materials-subtle-bg: var(--neutral-4);
  --materials-subtle-filter: none;
  --materials-subtle-backdrop-filter: none;
}

:root[data-material-mode="glass"] {
  --materials-elevated-bg: var(--neutral-0-a80);
  --materials-elevated-filter: none;
  --materials-elevated-backdrop-filter: blur(var(--blur-xl));
  --materials-base-bg: var(--neutral-1-a72);
  --materials-base-filter: none;
  --materials-base-backdrop-filter: blur(var(--blur-l));
  --materials-muted-bg: var(--neutral-2-a64);
  --materials-muted-filter: none;
  --materials-muted-backdrop-filter: blur(var(--blur-l));
  --materials-soft-bg: var(--neutral-3-a56);
  --materials-soft-filter: none;
  --materials-soft-backdrop-filter: blur(var(--blur-m));
  --materials-subtle-bg: var(--neutral-4-a48);
  --materials-subtle-filter: none;
  --materials-subtle-backdrop-filter: blur(var(--blur-m));
}

:root[data-material-mode="backdrop"] {
  --materials-elevated-bg: var(--neutral-0);
  --materials-elevated-filter: blur(var(--blur-s));
  --materials-elevated-backdrop-filter: none;
  --materials-base-bg: var(--neutral-1);
  --materials-base-filter: blur(var(--blur-s));
  --materials-base-backdrop-filter: none;
  --materials-muted-bg: var(--neutral-2);
  --materials-muted-filter: blur(var(--blur-xs));
  --materials-muted-backdrop-filter: none;
  --materials-soft-bg: var(--neutral-3);
  --materials-soft-filter: blur(var(--blur-xs));
  --materials-soft-backdrop-filter: none;
  --materials-subtle-bg: var(--neutral-4);
  --materials-subtle-filter: blur(var(--blur-xxs));
  --materials-subtle-backdrop-filter: none;
}
"
`;
